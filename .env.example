# ============================================================
# ElevenBoss — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file containing credentials.
# ============================================================

# ── Discord ──────────────────────────────────────────────────
# Your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Optional: Your dev/test Discord server ID for instant slash command sync.
# Leave empty or omit in production.
GUILD_ID=your_development_guild_id_here

# ── Supabase ──────────────────────────────────────────────────
# Your Supabase project URL and API key (service role on trusted bot server)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_service_role_key_here

# Direct Postgres URL for migrations and ops scripts (optional for bot-only dev)
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres

# ── Top.gg ────────────────────────────────────────────────────
# API token from your bot listing → Integrations & API (vote verification for free pack)
TOPGG_TOKEN=your_topgg_api_token_here
# Top.gg listing bot snowflake — set when dev/prod Discord app IDs differ from the listing
TOPGG_BOT_ID=1521477038270189638

# ── Environment Label ─────────────────────────────────────────
# Used for tagging execution environment (e.g. development, staging, production)
ENVIRONMENT=development
