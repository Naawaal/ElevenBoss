# ============================================================
# ElevenBoss — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file.
# ============================================================

# ── Discord ──────────────────────────────────────────────────
# Your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# ── Sentry (Error Tracking) ───────────────────────────────────
# DSN from https://sentry.io → Project Settings → Client Keys
# Leave blank to disable error tracking (not recommended in production).
SENTRY_DSN=

# ── Development ───────────────────────────────────────────────
# Optional: Your dev/test Discord server ID.
# When set, slash commands are synced to this guild instantly (no 1-hour wait).
# Remove or leave blank for global sync in production.
GUILD_ID=

# ── Environment Label ─────────────────────────────────────────
# Used by Sentry to tag events. Values: development | staging | production
ENVIRONMENT=development
