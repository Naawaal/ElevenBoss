# ============================================================
# ElevenBoss — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file containing credentials.
# ============================================================

# ── Discord ──────────────────────────────────────────────────
# Your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Optional: Your dev/test Discord server ID for instant slash command sync.
# Leave empty or omit in production.
GUILD_ID=your_development_guild_id_here

# ── Supabase ──────────────────────────────────────────────────
# Your Supabase project URL and API key (anon key)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_public_key_here

# ── Environment Label ─────────────────────────────────────────
# Used for tagging execution environment (e.g. development, staging, production)
ENVIRONMENT=development
