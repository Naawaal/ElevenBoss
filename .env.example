# ============================================================
# ElevenBoss — Environment Variables Template
# Copy this file to .env and fill in real values.
# NEVER commit the real .env file.
# ============================================================

# ── Discord ──────────────────────────────────────────────────
# Your bot token from https://discord.com/developers/applications
DISCORD_TOKEN=

# Primary command prefix fallback (if slash commands aren't used)
COMMAND_PREFIX=!

# ── Sentry (Error Tracking) ───────────────────────────────────
# DSN from https://sentry.io → Project Settings → Client Keys
# Leave blank to disable error tracking (not recommended in production).
SENTRY_DSN=

# ── Development ───────────────────────────────────────────────
# Optional: Your dev/test Discord server ID (for instant sync of slash commands during dev).
GUILD_ID=

# ── Environment Label ─────────────────────────────────────────
# Used by Sentry and logging. Values: development | staging | production
ENVIRONMENT=development

# ── Logging ───────────────────────────────────────────────────
# Minimum logging level. Values: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
